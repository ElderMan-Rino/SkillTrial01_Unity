.start-root {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    background-color: rgb(0, 0, 0);
    align-items: center;
    justify-content: center;
}

.start-image {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    background-image: url("../../Images/Splash/TempSplash.png");
    -unity-background-scale-mode: scale-and-crop;
}